{
  "name": "danaroute",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "build": "next build",
    "build:analyze": "cross-env ANALYZE=true npm run build",
    "build:debug-memory": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" next build --experimental-debug-memory-usage",
    "build:heap-profile": "node --heap-prof --max-old-space-size=4096 node_modules/next/dist/bin/next build",
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=2048 next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.8",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@types/qrcode": "^1.5.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "speakeasy": "^2.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
